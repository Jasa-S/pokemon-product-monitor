DISCORD_WEBHOOK_URL=
WATCH_PRODUCT_NOS=133526939,133699298
WATCH_KEYWORDS=
POLL_SECONDS=600
DATABASE_PATH=/data/monitor.db
NOTIFY_ON_FIRST_RUN=false
RUN_ONCE=false
SCAN_FULL_CATALOG=false
WATCHLIST_PATH=watchlist.json

# Optional outside GitHub Actions; enables English titles in Discord alerts.
GITHUB_MODELS_TOKEN=

# Optional: official Naver Shopping Search API for discovery-only Naver feeds.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_XOPLAY_QUERIES=XOPLAY 포켓몬,엑스오플레이 포켓몬,XOPLAY 포켓몬카드,엑스오플레이 포켓몬카드,포켓몬카드,포켓몬 카드
NAVER_POKEMON_QUERIES=포켓몬 스토어 온라인,포켓몬센터 공식,포켓몬센터
CHECK_NAVER_PUBLIC=true
EXTERNAL_STORE_INTERVAL_SECONDS=600
