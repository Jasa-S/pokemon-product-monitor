DISCORD_WEBHOOK_URL=
WATCH_PRODUCT_NOS=133526939,133699298
WATCH_KEYWORDS=
POLL_SECONDS=600
DATABASE_PATH=/data/monitor.db
NOTIFY_ON_FIRST_RUN=false
RUN_ONCE=false
SCAN_FULL_CATALOG=false
